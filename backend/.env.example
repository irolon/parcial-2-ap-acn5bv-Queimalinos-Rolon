# ── Servidor ────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Supabase ────────────────────────────────
# Settings → API en el dashboard de Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT ─────────────────────────────────────
# Secreto para firmar los tokens de acceso. Mínimo 32 caracteres aleatorios.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── n8n (chat IA) — se usa en fases posteriores ──
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
